# Keep source-controlled text files stable across Windows/Linux.
* text=auto

*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.css text eol=lf
*.html text eol=lf
*.cpp text eol=lf
*.cc text eol=lf
*.h text eol=lf
*.cu text eol=lf
*.cuh text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
